{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"skipLibCheck": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true,
		"lib": [
			"DOM",
			"ESNext"
		]
	},
	"include": [
		"**/*.ts"
	]
}
